# extra cloud things
if [ $spicelevel == "fog" ]; then
	logger -t sng "Additional cloud utilities on ${spicelevel}"
	in-target apt-get -y install cloud-init cloud-utils
fi

# consider the free and non-free firmware
if [ $spicelevel == "oso" ]; then
	logger -t sng "Use free firmware only on ${spicelevel}"
	in-target apt-get -y install firmware-linux-free
else
	logger -t sng "Use all available firmware on ${spicelevel}"
	in-target apt-get -y install firmware-linux
fi

# may need to lock the kernel for DAHDI
if [ $spicelevel == "oso" ]; then
	logger -t sng "DO NOT LOCK IN the kernel on ${spicelevel}"
	in-target apt-get -y install linux-image-amd64
elif [ $spicelevel == "fog" ]; then
	logger -t sng "DO NOT LOCK IN the kernel on ${spicelevel} but use special cloud image"
	in-target apt-get -y install linux-image-cloud-amd64
else
	logger -t sng "TRYING TO LOCK IN the kernel on ${spicelevel}"
	if [ -z "{{ str_locked_kernel }}" ]; then
		logger -t sng "COULD NOT LOCK IN the kernel on ${spicelevel}"
		in-target apt-get -y install linux-image-amd64
	else
		# freeze right there kernel, DAHDI would like a word with you
		logger -t sng "LOCK IN the kernel to {{ str_locked_kernel }}"
		# TODO: DAHDI building with DKMS so we can automatically match kernel updates (hmm, compiler)

		# copy the kernel packages from cdrom to target
		cp -a /cdrom/pool/main/l/linux/*.deb /target/var/tmp/ || true
		cp -a /cdrom/pool/main/l/linux-base/*.deb /target/var/tmp/ || true
		cp -a /cdrom/pool/main/l/linux-signed-amd64/*.deb /target/var/tmp/ || true
		cp -a /cdrom/pool/main/l/linux-signed-amd64/*.udeb /target/var/tmp/ || true

		# only on PXE cobbler installs
		if [ -n "${tftphost}" ] && [ -n "{{ str_cob_base }}" ]; then
			logger -t sng "Downloading kernel packages from Cobbler server"
			wget -q -O /cdrom/dahdi-supported-linux.list http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/dahdi-supported-linux.list || true
			wget -q -O /cdrom/dahdi-supported-linux-base.list http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/dahdi-supported-linux-base.list || true
			wget -q -O /cdrom/dahdi-supported-linux-signed-amd64.list http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/dahdi-supported-linux-signed-amd64.list || true
			sed "s|^|http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/pool/main/l/linux/|" /cdrom/dahdi-supported-linux.list > /target/tmp/dahdi-supported-linux.urls
			sed "s|^|http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/pool/main/l/linux-base/|" /cdrom/dahdi-supported-linux-base.list > /target/tmp/dahdi-supported-linux-base.urls
			sed "s|^|http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/pool/main/l/linux-signed-amd64/|" /cdrom/dahdi-supported-linux-signed-amd64.list > /target/tmp/dahdi-supported-linux-signed-amd64.urls
			in-target wget -q -i /tmp/dahdi-supported-linux.urls -P /var/tmp/
			in-target wget -q -i /tmp/dahdi-supported-linux-base.urls -P /var/tmp/
			in-target wget -q -i /tmp/dahdi-supported-linux-signed-amd64.urls -P /var/tmp/
		fi

		# prerequired manual packages (automatically included with linux-image-amd64)
		in-target apt-get -y install \
			apparmor \
			busybox \
			initramfs-tools \
			initramfs-tools-core \
			klibc-utils \
			libklibc \
			linux-base
		# the locked kernel will almost always require manual dpkg install (since it won't be on the stock ISO)
		fishing=$(ls /target/var/tmp/linux-image* | grep -m 1 "{{ str_locked_kernel }}" | cut -f3-8 -d/)
		in-target apt-get -y install linux-image-{{ str_locked_kernel }} || in-target dpkg -i $fishing
	fi
fi

in-target sync

