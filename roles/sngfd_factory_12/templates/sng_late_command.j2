set -e

# copy additional package files (if any) to widened target for faster installations
if [ $spicelevel != "oso" ] && [ $spicelevel != "fog" ] && [ -s /cdrom/Packages-sngfd.gz ]; then
	mkdir -p /target/var/spool/packages-sngfd/dists/{{ str_deb_codename }}/main/binary-amd64/pool/sngfd
	zcat /cdrom/Packages-sngfd.gz > /target/var/spool/packages-sngfd/dists/{{ str_deb_codename }}/main/binary-amd64/Packages
	if [ -z "${tftphost}" ]; then
		cp -a /cdrom/packages-sngfd/*.deb /target/var/spool/packages-sngfd/dists/{{ str_deb_codename }}/main/binary-amd64/pool/sngfd/
	else
		logger -t sng "Downloading additional packages from Cobbler server"
		grep "^Filename" /target/var/spool/packages-sngfd/dists/{{ str_deb_codename }}/main/binary-amd64/Packages | cut -f7 -d/ | sed "s|^|http://${tftphost}/cobbler/links/{{ str_cob_base }}-x86_64/packages-sngfd/|" > /target/tmp/packages-sngfd.urls
		in-target wget -q -i /tmp/packages-sngfd.urls -P /var/spool/packages-sngfd/dists/{{ str_deb_codename }}/main/binary-amd64/pool/sngfd/
	fi
fi

# install a bunch of things at once to speed up the shell installer later on
# (ripped these lines right out of the shell installer)
